# Copy this file to .env.local and fill in your values
# .env.local is gitignored and safe for secrets

# Google AI (Gemini) for food analysis
EXPO_PUBLIC_FOOD_AI_KEY=your_google_ai_api_key

# RevenueCat (iOS production key starts with appl_, test key starts with test_)
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_your_revenuecat_api_key
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=GERD Buddy Pro
EXPO_PUBLIC_REVENUECAT_PAYWALL_ID=your_paywall_id
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=gerd-buddy

# PostHog Analytics
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_posthog_key

# App Store Connect API (for submission)
APPLE_API_KEY_ID=your_key_id
APPLE_API_ISSUER_ID=your_issuer_uuid
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----"

# Optional: Debug/Development flags
# EXPO_PUBLIC_FOOD_AI_DEBUG=false
# EXPO_PUBLIC_BYPASS_PAYWALL=true
